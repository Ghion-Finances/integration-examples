# Ghion Gateway API Configuration
# Get these from Dashboard -> API Credentials
GHION_API_KEY=your_api_key_here
GHION_API_SECRET=your_api_secret_here
# IMPORTANT: Use the RAW passphrase shown when you generated credentials.
# The passphrase is only shown once. Do NOT base64-encode it.
GHION_API_PASSPHRASE=your_passphrase_here
GHION_BASE_URL=https://ghion.financial
GHION_MODE=test

# Application Configuration
APP_URL=http://localhost:3001
APP_ENV=development
