{
    "name": "ghion/hosted-checkout-example",
    "description": "Production-ready hosted checkout integration example for Ghion Finances",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Ghion\\HostedCheckout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghion\\HostedCheckout\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=PSR12 src/",
        "phpstan": "phpstan analyse src/ --level=8",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    }
}
