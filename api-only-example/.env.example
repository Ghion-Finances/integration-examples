# API credentials from Dashboard -> API Credentials
GHION_API_KEY=your_api_key
GHION_API_SECRET=your_api_secret
# IMPORTANT: Use the RAW passphrase shown when you generated credentials.
# The passphrase is only shown once. Do NOT base64-encode it.
GHION_API_PASSPHRASE=your_passphrase

GHION_BASE_URL=https://ghion.financial/api/v1
GHION_MODE=test
PORT=3003
